#!/usr/bin/env bash
#MISE description="Run plugin tests - install and execute tool"
set -euo pipefail

mise plugin link --force zls .
mise cache clear
mise install zls@master

# Capture and display the output while also verifying it
output=$(mise exec "zls@master" -- "zls" --version)
echo "zls output: $output"

if echo "$output" | grep -q '0.16.0-dev'; then
    echo "✓ Tests passed"
else
    echo "✗ Test failed: expected version 0.16.0-dev"
    exit 1
fi
